  ],
  "refresh": "5s",
  "schemaVersion": 39,
  "tags": [
    "openinfer",
    "vllm",
    "inference"
  ],
  "templating": {
    "list": [
      {
        "allValue": ".*",
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        },
        "datasource": {
          "type": "prometheus",
          "uid": "${DS_PROMETHEUS}"
        },
        "definition": "label_values(vllm:request_success_total, model_name)",
        "hide": 0,
        "includeAll": true,
        "label": "Model",
        "multi": true,
        "name": "model_name",
        "options": [],
        "query": {
          "query": "label_values(vllm:request_success_total, model_name)",
          "refId": "StandardVariableQuery"
        },
        "refresh": 1,
        "regex": "",
        "skipUrlSync": false,
        "sort": 1,
        "type": "query"
      }
    ]
  },
  "time": {
    "from": "now-15m",
    "to": "now"
  },
  "timepicker": {},
  "timezone": "browser",
  "title": "OpenInfer Serving",
  "uid": "openinfer-serving",
  "version": 1,
  "weekStart": ""
}
